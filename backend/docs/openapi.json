  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "isActive": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ProductInput": {
        "type": "object",
        "required": [
          "productName",
          "productType",
          "procurementStrategy",
          "procurementType"
        ],
        "properties": {
          "productName": {
            "type": "string",
            "example": "Steel Pinion"
          },
          "description": {
            "type": "string"
          },
          "salesPrice": {
            "type": "number",
            "minimum": 0
          },
          "costPrice": {
            "type": "number",
            "minimum": 0
          },
          "productType": {
            "type": "string",
            "enum": [
              "FINISHED_GOOD",
              "RAW_MATERIAL",
              "COMPONENT"
            ]
          },
          "procurementStrategy": {
            "type": "string",
            "enum": [
              "MTS",
              "MTO"
            ]
          },
          "procurementType": {
            "type": "string",
            "enum": [
              "PURCHASE",
              "MANUFACTURING"
            ]
          },
          "vendor": {
            "type": "string"
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "totalPages": {
            "type": "integer"
          },
          "hasNextPage": {
            "type": "boolean"
          },
          "hasPrevPage": {
            "type": "boolean"
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "customerCode": {
            "type": "string"
          },
          "customerName": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "gstNumber": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "pincode": {
            "type": "string"
          },
          "isActive": {
            "type": "boolean"
          }
        }
      },
      "CustomerInput": {
        "type": "object",
        "required": [
          "customerName",
          "email",
          "phone",
          "address",
          "city",
          "state",
          "country",
          "pincode"
        ],
        "properties": {
          "customerName": {
            "type": "string",
            "example": "Apex Tech Builders"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "supplies@apextech.com"
          },
          "phone": {
            "type": "string",
            "example": "+91 9876543210"
          },
          "gstNumber": {
            "type": "string",
            "example": "19BBBBB2222B2Z2"
          },
          "address": {
            "type": "string",
            "example": "402 Cyber Towers"
          },
          "city": {
            "type": "string",
            "example": "Hyderabad"
          },
          "state": {
            "type": "string",
            "example": "Telangana"
          },
          "country": {
            "type": "string",
            "example": "India"
          },
          "pincode": {
            "type": "string",
            "example": "500081"
          }
        }
      },
      "SalesOrder": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "soNumber": {
            "type": "string"
          },
          "customerId": {
            "type": "string"
          },
          "orderDate": {
            "type": "string",
            "format": "date-time"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "productId": {
                  "type": "string"
                },
                "quantity": {
                  "type": "integer"
                },
                "unitPrice": {
                  "type": "number"
                },
                "totalPrice": {
                  "type": "number"
                }
              }
            }
          },
          "totalAmount": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": [
              "Draft",
              "Confirmed",
              "Partially Delivered",
              "Fully Delivered",
              "Cancelled"
            ]
          },
          "remarks": {
            "type": "string"
          },
          "createdBy": {
            "type": "string"
          }
        }
      },
      "SalesOrderInput": {
        "type": "object",
        "required": [
          "customerId",
          "items"
        ],
        "properties": {
          "customerId": {
            "type": "string",
            "example": "60d000000000000000000002"
          },
          "orderDate": {
            "type": "string",
            "format": "date-time"
          },
          "remarks": {
            "type": "string",
            "example": "Immediate dispatch required"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "productId",
                "quantity",
                "unitPrice"
              ],
              "properties": {
                "productId": {
                  "type": "string",
                  "example": "60d000000000000000000003"
                },
                "quantity": {
                  "type": "integer",
                  "example": 10
                },
                "unitPrice": {
                  "type": "number",
                  "example": 15.5
                }
              }
            }
          }
        }
      }
    }
  }
}